<?xml version="1.0" encoding="utf-8"?>
<!-- Home: Banking-app style — blue header, big safety score, data tiles, chart area, quick actions -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══ BLUE HEADER (Banking app style) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_blue_gradient"
            android:paddingHorizontal="24dp"
            android:paddingTop="44dp"
            android:paddingBottom="36dp">

            <!-- App bar row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SafeChain"
                        android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/text_on_blue" />
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/tagline"
                        android:textSize="11sp" android:textColor="@color/text_muted" />
                </LinearLayout>

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp">
                    <ImageView
                        android:id="@+id/ivNotification"
                        android:layout_width="40dp" android:layout_height="40dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="@color/text_muted"
                        android:contentDescription="Alerts"
                        android:padding="8dp" />
                    <View android:layout_width="9dp" android:layout_height="9dp"
                        android:layout_gravity="top|end" android:layout_margin="5dp"
                        android:background="@color/accent_amber" />
                </FrameLayout>
            </LinearLayout>

            <!-- BIG Safety Score (banking-app large number style) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Safety Score" android:textSize="12sp"
                        android:textColor="@color/text_muted" android:layout_marginBottom="4dp" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="bottom">
                        <TextView
                            android:id="@+id/tvSafetyScore"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="82"
                            android:textSize="52sp" android:textStyle="bold"
                            android:textColor="@color/text_on_blue" />
                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" /100" android:textSize="16sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginBottom="10dp" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvSafetyStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LOW RISK"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/accent_amber"
                        android:background="@drawable/bg_amber_chip"
                        android:paddingHorizontal="10dp" android:paddingVertical="4dp" />
                </LinearLayout>

                <!-- SOS (compact) -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <Button
                        android:id="@+id/btnSOS"
                        android:layout_width="90dp" android:layout_height="90dp"
                        android:text="SOS"
                        android:textSize="20sp" android:textStyle="bold"
                        android:textColor="@color/text_on_blue"
                        android:background="@drawable/bg_sos_button"
                        android:stateListAnimator="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hold 3s" android:textSize="10sp"
                        android:textColor="@color/text_muted" android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stat Tiles Row (Watch Duty style — ACRES / CONTAINMENT / STATUS) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#26FFFFFF"
                android:padding="14dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="REPORTS" android:textSize="9sp" android:textAllCaps="true"
                        android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvStatReports"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/text_on_blue" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="36dp"
                    android:background="@color/divider" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ALERTS" android:textSize="9sp" android:textAllCaps="true"
                        android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvStatAlerts"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/accent_amber" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="36dp"
                    android:background="@color/divider" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="RESOLVED" android:textSize="9sp" android:textAllCaps="true"
                        android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvStatResolved"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/accent_green" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ CONTENT AREA (white background) ═══ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp">

            <!-- Recent Incident Chart (banking app style) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_elevated"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Incident History" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Last 7 days ›" android:textSize="12sp"
                            android:textColor="@color/text_blue" />
                    </LinearLayout>

                    <!-- Simple bar chart using Views (no library) -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="80dp"
                        android:orientation="horizontal" android:gravity="bottom"
                        android:layout_marginBottom="6dp">
                        <View android:layout_width="0dp" android:layout_height="20dp"
                            android:layout_weight="1" android:layout_marginHorizontal="3dp"
                            android:background="@color/chart_bar" />
                        <View android:layout_width="0dp" android:layout_height="45dp"
                            android:layout_weight="1" android:layout_marginHorizontal="3dp"
                            android:background="@color/chart_bar" />
                        <View android:layout_width="0dp" android:layout_height="30dp"
                            android:layout_weight="1" android:layout_marginHorizontal="3dp"
                            android:background="@color/chart_bar" />
                        <View android:layout_width="0dp" android:layout_height="55dp"
                            android:layout_weight="1" android:layout_marginHorizontal="3dp"
                            android:background="@color/chart_bar_danger" />
                        <View android:layout_width="0dp" android:layout_height="35dp"
                            android:layout_weight="1" android:layout_marginHorizontal="3dp"
                            android:background="@color/chart_bar" />
                        <View android:layout_width="0dp" android:layout_height="25dp"
                            android:layout_weight="1" android:layout_marginHorizontal="3dp"
                            android:background="@color/chart_bar" />
                        <View android:layout_width="0dp" android:layout_height="70dp"
                            android:layout_weight="1" android:layout_marginHorizontal="3dp"
                            android:background="@color/chart_bar_active" />
                    </LinearLayout>

                    <!-- Day labels -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="M" android:textSize="10sp"
                            android:textColor="@color/text_muted" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="T" android:textSize="10sp"
                            android:textColor="@color/text_muted" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="W" android:textSize="10sp"
                            android:textColor="@color/text_muted" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="T" android:textSize="10sp"
                            android:textColor="@color/secondary" android:gravity="center" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="F" android:textSize="10sp"
                            android:textColor="@color/text_muted" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="S" android:textSize="10sp"
                            android:textColor="@color/text_muted" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="S" android:textSize="10sp"
                            android:textColor="@color/primary" android:gravity="center" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Actions Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quick Actions" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- 2x2 Action Grid -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">

                <androidx.cardview.widget.CardView android:id="@+id/cardCapture"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_camera" android:tint="@color/primary"
                            android:contentDescription="Camera" android:layout_marginBottom="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Evidence" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="LSB Sealed" android:textSize="10sp" android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/cardRecord"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@android:drawable/ic_btn_speak_now" android:tint="@color/status_submitted"
                            android:contentDescription="Record" android:layout_marginBottom="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Record" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Encrypted" android:textSize="10sp" android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView android:id="@+id/cardSafeRoute"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_mapmode" android:tint="@color/accent_amber"
                            android:contentDescription="Map" android:layout_marginBottom="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Safe Route" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Live heatmap" android:textSize="10sp" android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/cardCases"
                    android:layout_width="0dp" android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_agenda" android:tint="@color/accent_green"
                            android:contentDescription="Cases" android:layout_marginBottom="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="My Cases" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="On-chain" android:textSize="10sp" android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Community alert card (Watch Duty incident card style) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_elevated"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@color/secondary" android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Community Alert" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Active" android:textSize="10sp" android:textStyle="bold"
                            android:textColor="@color/secondary" android:background="@drawable/bg_badge_danger"
                            android:paddingHorizontal="8dp" android:paddingVertical="3dp" />
                    </LinearLayout>

                    <TextView android:id="@+id/tvAlertDesc"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="No recent incidents reported nearby in the last 2 hours. You are in a safe zone."
                        android:textSize="13sp" android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp" />

                    <!-- Watch Duty style data tiles -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="AREA" android:textSize="9sp" android:textAllCaps="true"
                                android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1km radius" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="INCIDENTS" android:textSize="9sp" android:textAllCaps="true"
                                android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                            <TextView android:id="@+id/tvAlertIncidents"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/secondary" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="STATUS" android:textSize="9sp" android:textAllCaps="true"
                                android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Active" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/secondary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
