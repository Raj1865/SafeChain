<?xml version="1.0" encoding="utf-8"?>
<!-- Case item: Watch Duty incident card with data tiles -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/bg_elevated"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Case ID + Status badge (Watch Duty: "Mosquito Fire 🔥 Active") -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvCaseId"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="cmp_12345" android:textSize="16sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:fontFamily="monospace" />
                <TextView android:id="@+id/tvSubmittedTime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Bengaluru, KA" android:textSize="12sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <TextView android:id="@+id/tvStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SUBMITTED" android:textSize="11sp" android:textStyle="bold"
                android:paddingHorizontal="10dp" android:paddingVertical="5dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginVertical="10dp" />

        <!-- Watch Duty data tile row: IPFS / TX / DEADLINE -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="IPFS CID" android:textSize="9sp" android:textAllCaps="true"
                    android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                <TextView android:id="@+id/tvIpfsCid"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="QmPend…" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/primary" android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="POLYGON TX" android:textSize="9sp" android:textAllCaps="true"
                    android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                <TextView android:id="@+id/tvTxHash"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0xPend…" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/primary" android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DEADLINE" android:textSize="9sp" android:textAllCaps="true"
                    android:textColor="@color/text_muted" android:letterSpacing="0.08" />
                <TextView android:id="@+id/tvDeadlineTime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="48h left" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Escalation warning bar -->
        <LinearLayout android:id="@+id/escalationWarning"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_danger"
            android:padding="10dp" android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:tint="@color/secondary" android:contentDescription="Warn"
                android:layout_marginEnd="8dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Smart Contract auto-escalation pending"
                android:textSize="11sp" android:textColor="@color/secondary" />
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnViewLifecycle"
                android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                android:text="Lifecycle ⟳" android:textAllCaps="false"
                android:textColor="@color/text_on_blue" android:textSize="12sp" android:textStyle="bold"
                android:background="@drawable/bg_glass_card"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnExportReport"
                android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                android:text="Export ↗" android:textAllCaps="false"
                android:textColor="@color/text_on_blue" android:textSize="12sp" android:textStyle="bold"
                android:background="@drawable/bg_button_primary" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
