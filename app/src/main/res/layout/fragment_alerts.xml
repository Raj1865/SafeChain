<?xml version="1.0" encoding="utf-8"?>
<!-- Alerts: Blue header + Watch Duty style alert cards -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Blue gradient header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_blue_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="44dp"
        android:paddingBottom="20dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Safety Alerts"
                    android:textSize="22sp" android:textStyle="bold"
                    android:textColor="@color/text_on_blue" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Predictive · Community-sourced"
                    android:textSize="12sp" android:textColor="#BBDEFB" />
            </LinearLayout>

            <Button android:id="@+id/btnRefreshAlerts"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Refresh"
                android:textAllCaps="false" android:textColor="@color/text_on_blue"
                android:textSize="12sp" android:textStyle="bold"
                android:background="@color/text_on_blue"
                android:paddingHorizontal="16dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Summary tile strip (Watch Duty data row style) -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_elevated"
        android:padding="16dp"
        android:elevation="2dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AREA RISK" android:textSize="9sp" android:textAllCaps="true"
                android:textColor="@color/text_muted" android:letterSpacing="0.08" />
            <TextView android:id="@+id/tvCurrentRisk"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MODERATE" android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/accent_amber" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="36dp" android:background="@color/divider" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="UNREAD" android:textSize="9sp" android:textAllCaps="true"
                android:textColor="@color/text_muted" android:letterSpacing="0.08" />
            <TextView android:id="@+id/tvUnreadCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/secondary" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="36dp" android:background="@color/divider" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SAFE ROUTES" android:textSize="9sp" android:textAllCaps="true"
                android:textColor="@color/text_muted" android:letterSpacing="0.08" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2 avail." android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/accent_green" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading indicator -->
    <LinearLayout android:id="@+id/llGenerating"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone" android:padding="14dp"
        android:background="@color/accent_amber_light">
        <ProgressBar android:layout_width="18dp" android:layout_height="18dp"
            android:indeterminate="true" android:indeterminateTint="@color/accent_amber"
            android:layout_marginEnd="10dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Analysing historical data + live inputs…"
            android:textSize="12sp" android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout android:id="@+id/llEmptyAlerts"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:padding="40dp" android:visibility="gone">
        <ImageView android:layout_width="56dp" android:layout_height="56dp"
            android:src="@drawable/ic_shield" android:contentDescription="Safe"
            android:layout_marginBottom="14dp" android:tint="@color/accent_green" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="All Clear" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/accent_green" android:layout_marginBottom="8dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="No alerts for your current location and time. Stay aware."
            android:textSize="13sp" android:textColor="@color/text_muted" android:gravity="center" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlerts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

</LinearLayout>
