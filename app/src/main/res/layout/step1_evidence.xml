<?xml version="1.0" encoding="utf-8"?>
<!-- Step 1: Secure Evidence -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="1. Secure Evidence"
            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Photos captured here are embedded with GPS coordinates, device hash, and timestamp via LSB steganography — invisible and permanent."
            android:textSize="14sp" android:textColor="@color/text_muted"
            android:layout_marginBottom="24dp" />

        <!-- Camera Capture Area -->
        <FrameLayout
            android:id="@+id/captureArea"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_capture_area"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/capturePlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:tint="#66FFFFFF"
                    android:contentDescription="Camera"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to Open Camera"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Metadata embedded automatically"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivCaptured"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Captured evidence" />

            <TextView
                android:id="@+id/tvLsbSealed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:text="🔒 LSB Sealed"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:background="@drawable/bg_badge_success"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnChooseGallery"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Gallery"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_glass_card"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnRecordAudio"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Hold to Record"
                android:textAllCaps="false"
                android:textColor="@color/secondary"
                android:background="@drawable/bg_glass_card" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStep1Next"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Continue →"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary" />
    </LinearLayout>
</ScrollView>
