<?xml version="1.0" encoding="utf-8"?>
<!-- Evidence item card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/bg_elevated"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView android:id="@+id/ivEvidenceThumb"
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:tint="@color/primary"
                android:contentDescription="Evidence"
                android:background="@drawable/bg_action_card"
                android:padding="12dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvEvidenceType"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Photo Evidence"
                    android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView android:id="@+id/tvEvidenceDate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mar 30, 2026 · 14:30"
                    android:textSize="12sp" android:textColor="@color/text_muted" />
            </LinearLayout>

            <TextView android:id="@+id/tvEvidenceBadge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sealed"
                android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:paddingHorizontal="8dp" android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_success" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border_light" android:layout_marginBottom="12dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SHA-256 Hash:" android:textSize="11sp"
                android:textColor="@color/text_muted" />
            <TextView android:id="@+id/tvHash"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3a1f8b2c…"
                android:textSize="11sp" android:textColor="@color/accent_cyan"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="IPFS CID:" android:textSize="11sp"
                android:textColor="@color/text_muted" />
            <TextView android:id="@+id/tvIpfsCid"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="QmXyz8F3…"
                android:textSize="11sp" android:textColor="@color/accent_cyan"
                android:fontFamily="monospace" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
