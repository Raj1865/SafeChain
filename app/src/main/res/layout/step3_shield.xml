<?xml version="1.0" encoding="utf-8"?>
<!-- Step 3: ZK Identity Shield -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="3. Identity Shield"
            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="A Zero-Knowledge proof proves you are a verified user in this area without revealing who you are."
            android:textSize="14sp" android:textColor="@color/text_muted"
            android:layout_marginBottom="28dp" />

        <!-- ZK Proof Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/bg_elevated"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <ImageView
                    android:id="@+id/ivZkShield"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_shield"
                    android:contentDescription="ZK Shield"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvZkTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZK Proof Ready"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvZkProof"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="π = 0x1a7f3d8c…c4e9\nVerified: User in valid district"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card"
                    android:padding="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@android:drawable/checkbox_on_background"
                            android:tint="@color/accent_green"
                            android:contentDescription="Check"
                            android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Identity never transmitted" android:textSize="13sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@android:drawable/checkbox_on_background"
                            android:tint="@color/accent_green"
                            android:contentDescription="Check"
                            android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Phone number stays private" android:textSize="13sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@android:drawable/checkbox_on_background"
                            android:tint="@color/accent_green"
                            android:contentDescription="Check"
                            android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Complaint is cryptographically verifiable" android:textSize="13sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Blockchain Spinner (shown during submit) -->
        <LinearLayout
            android:id="@+id/llSubmitting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/primary"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Uploading to IPFS &amp; sealing on Polygon…"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:gravity="center" />
        </LinearLayout>

        <Button android:id="@+id/btnSubmit"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="File Anonymous Complaint"
            android:textAllCaps="false" android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnStep3Back"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="← Back" android:textAllCaps="false" android:textColor="@color/text_primary"
            android:background="@drawable/bg_glass_card" />
    </LinearLayout>
</ScrollView>
